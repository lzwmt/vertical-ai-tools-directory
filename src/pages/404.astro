---
import BaseLayout from "@/layouts/BaseLayout.astro";
---

<BaseLayout title="页面不存在" description="找不到你访问的页面。">
  <section class="container-shell py-24 text-center">
    <p class="eyebrow">404</p>
    <h1 class="mt-4 text-5xl font-black">页面不存在</h1>
    <p class="mt-4 text-[color:var(--ink-muted)]">你可以返回首页重新浏览工具与分类。</p>
    <a href="/" class="mt-8 inline-flex rounded-full bg-[color:var(--accent)] px-5 py-3 font-semibold text-white">返回首页</a>
  </section>
</BaseLayout>
