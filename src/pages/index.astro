---
import { getCollection } from "astro:content";
import BaseLayout from "@/layouts/BaseLayout.astro";
import SearchForm from "@/components/forms/SearchForm.astro";
import NewsletterForm from "@/components/forms/NewsletterForm.astro";
import SectionHeading from "@/components/site/SectionHeading.astro";
import ToolCard from "@/components/site/ToolCard.astro";

const tools = await getCollection("tools");
const categories = await getCollection("categories");
const comparisons = await getCollection("comparisons");
const useCases = await getCollection("use-cases");
const newsletterStatus = Astro.url.searchParams.get("newsletter");
const newsletterReason = Astro.url.searchParams.get("reason");
---

<BaseLayout title="AI 工具垂直导航" description="面向中文内容创作者的 AI 工具发现与比较站点。">
  <section class="container-shell py-16 md:py-24">
    <div class="grid items-end gap-10 lg:grid-cols-[1.3fr_0.7fr]">
      <div class="space-y-6">
        <p class="eyebrow">Curated For Chinese Ops Teams</p>
        <h1 class="max-w-4xl text-5xl font-black tracking-tight md:text-7xl">
          帮中文内容团队更快筛到真正能落地的 AI 工具
        </h1>
        <p class="max-w-2xl text-lg leading-8 text-[color:var(--ink-muted)]">
          聚焦写作、协作、内容工作流与中国区可用性。不是列一堆产品，而是给出可执行的选型判断。
        </p>
        <SearchForm />
      </div>
      <div class="card-surface p-8">
        <p class="text-sm font-semibold text-[color:var(--accent-deep)]">本周导航重点</p>
        <div class="mt-6 space-y-5">
          <div>
            <p class="text-sm text-[color:var(--ink-muted)]">精选分类</p>
            <a href={`/categories/${categories[0].data.slug}`} class="mt-1 block text-2xl font-bold">
              {categories[0].data.name}
            </a>
          </div>
          <div>
            <p class="text-sm text-[color:var(--ink-muted)]">最新对比</p>
            <a href={`/compare/${comparisons[0].data.slug}`} class="mt-1 block text-2xl font-bold">
              {comparisons[0].data.title}
            </a>
          </div>
          <div>
            <p class="text-sm text-[color:var(--ink-muted)]">场景入口</p>
            <a href={`/use-cases/${useCases[0].data.slug}`} class="mt-1 block text-2xl font-bold">
              {useCases[0].data.title}
            </a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="container-shell space-y-8 py-8">
    <SectionHeading eyebrow="Editor Picks" title="编辑精选工具" summary="先给两条清晰路径：工作流一体化，或者营销文案规模化。" />
    <div class="grid gap-6 md:grid-cols-2">
      {tools.map((tool) => <ToolCard tool={tool} />)}
    </div>
  </section>

  <section class="container-shell py-12">
    <SectionHeading eyebrow="Newsletter" title="每周一次，更新值得关注的新工具与新结论" />
    <div class="mt-8">
      <NewsletterForm
        source="homepage"
        status={newsletterStatus === "success" || newsletterStatus === "error" ? newsletterStatus : undefined}
        reason={newsletterReason}
      />
    </div>
  </section>
</BaseLayout>
