---
import type { ToolFilters } from "@/lib/validation/filters";

interface Props {
  action?: string;
  filters?: Partial<ToolFilters>;
}

const { action = "/categories/ai-writing", filters = {} } = Astro.props;
---

<form action={action} class="grid gap-3 md:grid-cols-[2fr_repeat(4,minmax(0,1fr))]">
  <input
    type="search"
    name="q"
    value={filters.q}
    placeholder="搜索工具名、标签或摘要"
    class="editorial-field"
  />
  <select name="priceTier" class="editorial-field">
    <option value="all" selected={filters.priceTier === "all"}>全部价格</option>
    <option value="free" selected={filters.priceTier === "free"}>免费</option>
    <option value="freemium" selected={filters.priceTier === "freemium"}>Freemium</option>
    <option value="paid" selected={filters.priceTier === "paid"}>付费</option>
    <option value="enterprise" selected={filters.priceTier === "enterprise"}>企业版</option>
  </select>
  <select name="supportsChinese" class="editorial-field">
    <option value="all" selected={filters.supportsChinese === "all"}>中文支持</option>
    <option value="true" selected={filters.supportsChinese === "true"}>支持中文</option>
    <option value="false" selected={filters.supportsChinese === "false"}>不支持中文</option>
  </select>
  <select name="availableInChina" class="editorial-field">
    <option value="all" selected={filters.availableInChina === "all"}>中国可访问</option>
    <option value="true" selected={filters.availableInChina === "true"}>可访问</option>
    <option value="false" selected={filters.availableInChina === "false"}>不可访问</option>
  </select>
  <select name="beginnerFriendly" class="editorial-field">
    <option value="all" selected={filters.beginnerFriendly === "all"}>上手门槛</option>
    <option value="true" selected={filters.beginnerFriendly === "true"}>适合新手</option>
    <option value="false" selected={filters.beginnerFriendly === "false"}>偏进阶</option>
  </select>
  <button type="submit" class="editorial-button editorial-button-primary">筛选</button>
</form>
