---
import type { ToolFilters } from "@/lib/validation/filters";

interface Props {
  action?: string;
  filters?: Partial<ToolFilters>;
}

const { action = "/categories/ai-writing", filters = {} } = Astro.props;
---

<form action={action} class="grid gap-3 md:grid-cols-[2fr_repeat(4,minmax(0,1fr))]">
  <input
    type="search"
    name="q"
    value={filters.q}
    placeholder="搜索工具名、标签或摘要"
    class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3"
  />
  <select name="priceTier" class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3">
    <option value="all">全部价格</option>
    <option value="free">免费</option>
    <option value="freemium">Freemium</option>
    <option value="paid">付费</option>
    <option value="enterprise">企业版</option>
  </select>
  <select name="supportsChinese" class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3">
    <option value="all">中文支持</option>
    <option value="true">支持中文</option>
    <option value="false">不支持中文</option>
  </select>
  <select name="availableInChina" class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3">
    <option value="all">中国可访问</option>
    <option value="true">可访问</option>
    <option value="false">不可访问</option>
  </select>
  <select name="beginnerFriendly" class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3">
    <option value="all">上手门槛</option>
    <option value="true">适合新手</option>
    <option value="false">偏进阶</option>
  </select>
  <button class="rounded-2xl bg-[color:var(--accent)] px-4 py-3 font-semibold text-white">筛选</button>
</form>
