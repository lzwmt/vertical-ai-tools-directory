---
interface Props {
  source?: string;
  status?: "success" | "error";
  reason?: string | null;
}

const { source = "site", status, reason } = Astro.props;
---

{
  status === "success" && (
    <div class="mb-4 rounded-2xl border border-emerald-200 bg-emerald-50 px-4 py-3 text-sm text-emerald-800">
      订阅已记录，后续会按周发送精选更新。
    </div>
  )
}
{
  status === "error" && (
    <div class="mb-4 rounded-2xl border border-amber-200 bg-amber-50 px-4 py-3 text-sm text-amber-900">
      {reason === "database" ? "当前订阅服务未配置完成，请稍后再试。" : "订阅失败，请检查邮箱格式后重试。"}
    </div>
  )
}
<form method="post" action="/api/newsletter" class="card-surface grid gap-3 p-6 md:grid-cols-[2fr_1fr]">
  <input type="hidden" name="source" value={source} autocomplete="off" />
  <input
    required
    type="email"
    name="email"
    autocomplete="email"
    placeholder="输入邮箱，接收每周 AI 工具精选"
    class="rounded-2xl border border-[color:var(--line)] bg-white/70 px-4 py-3"
  />
  <button class="rounded-2xl bg-[color:var(--accent)] px-4 py-3 font-semibold text-white">订阅</button>
</form>
