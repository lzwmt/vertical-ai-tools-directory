---
interface Props {
  eyebrow?: string;
  title: string;
  summary?: string;
}

const { eyebrow, title, summary } = Astro.props;
---

<div class="max-w-3xl">
  {eyebrow && <p class="eyebrow mb-3">{eyebrow}</p>}
  <h2 class="editorial-title">{title}</h2>
  {summary && <p class="mt-4 max-w-2xl text-base leading-8 text-[color:var(--ink-muted)]">{summary}</p>}
</div>
