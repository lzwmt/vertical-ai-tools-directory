---
import { resolveAssetPath } from "@/lib/assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  tool: CollectionEntry<"tools">;
}

const { tool } = Astro.props;
---

<article class="card-surface overflow-hidden">
  <img src={resolveAssetPath(tool.data.screenshot)} alt={tool.data.name} class="h-44 w-full object-cover" />
  <div class="space-y-4 p-6">
    <div class="flex items-start justify-between gap-4">
      <div>
        <h3 class="text-xl font-bold">
          <a href={`/tools/${tool.data.slug}`}>{tool.data.name}</a>
        </h3>
        <p class="mt-2 text-sm text-[color:var(--ink-muted)]">{tool.data.tagline}</p>
      </div>
      <span class="rounded-full border border-[color:var(--line)] px-3 py-1 text-xs font-semibold">
        {tool.data.priceLabel}
      </span>
    </div>
    <p class="text-sm leading-6 text-[color:var(--ink-muted)]">{tool.data.summary}</p>
    <div class="flex flex-wrap gap-2 text-xs">
      {tool.data.tags.map((tag) => <span class="rounded-full bg-white/70 px-3 py-1">{tag}</span>)}
    </div>
  </div>
</article>
