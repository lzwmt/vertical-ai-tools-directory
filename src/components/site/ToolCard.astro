---
import { resolveAssetPath } from "@/lib/assets";
import type { CollectionEntry } from "astro:content";

interface Props {
  tool: CollectionEntry<"tools">;
  hideVisualHeader?: boolean;
  hideScreenshotLink?: boolean;
}

const { tool, hideVisualHeader = false, hideScreenshotLink = false } = Astro.props;
const initials = tool.data.name
  .split(/\s+/)
  .map((part) => part[0] ?? "")
  .join("")
  .slice(0, 3)
  .toUpperCase();
---

<article class="card-surface group overflow-hidden">
  {!hideVisualHeader && (
    <div class="border-b border-[color:var(--line)] bg-[linear-gradient(180deg,rgba(241,237,236,0.9),rgba(253,248,247,0.96))] p-6">
      <div class="flex items-start justify-between gap-5">
        <div class="flex h-16 w-16 items-center justify-center bg-[color:var(--surface-strong)] font-['Noto_Serif_SC'] text-2xl font-semibold text-[color:var(--accent)]">
          {initials}
        </div>
        <span class="bg-[rgba(138,90,54,0.1)] px-3 py-1 text-[10px] font-semibold uppercase tracking-[0.18em] text-[color:var(--accent)]">
          {tool.data.priceLabel}
        </span>
      </div>
      <div class="mt-6">
        <p class="text-xs uppercase tracking-[0.18em] text-[color:var(--ink-soft)]">{tool.data.name}</p>
        <p class="mt-2 text-sm leading-7 text-[color:var(--ink-muted)]">{tool.data.tagline}</p>
      </div>
    </div>
  )}
  <div class="flex h-full flex-col p-6">
    <div class="flex items-start justify-between gap-4">
      <div class="flex-1">
        <p class="eyebrow mb-2">{tool.data.tags[0] ?? "Editor Pick"}</p>
        <h3 class="editorial-heading">
          <a href={`/tools/${tool.data.slug}`}>{tool.data.name}</a>
        </h3>
        <p class="mt-2 text-sm text-[color:var(--ink-muted)]">{tool.data.tagline}</p>
      </div>
    </div>
    <div class="flex flex-1 flex-col justify-between gap-5 pt-5">
      <p class="text-sm leading-6 text-[color:var(--ink-muted)]">{tool.data.summary}</p>
      <div class="space-y-5">
        <div class="flex flex-wrap gap-2 text-xs">
          {tool.data.tags.map((tag) => <span class="border border-[color:var(--line)] px-3 py-1 text-[color:var(--ink-soft)]">{tag}</span>)}
        </div>
        {!hideScreenshotLink && (
          <a href={resolveAssetPath(tool.data.screenshot)} class="text-xs uppercase tracking-[0.18em] text-[color:var(--ink-soft)] transition hover:text-[color:var(--accent)]">
            查看原始截图
          </a>
        )}
        <a href={`/tools/${tool.data.slug}`} class="inline-flex items-center gap-2 text-sm font-medium text-[color:var(--ink)] transition hover:text-[color:var(--accent)]">
          查看评测
          <span aria-hidden="true">→</span>
        </a>
      </div>
    </div>
  </div>
</article>
