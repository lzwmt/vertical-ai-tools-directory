{
  "name": "vertical-ai-tools-directory",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@10.17.1",
  "scripts": {
    "dev": "ASTRO_TELEMETRY_DISABLED=1 astro dev",
    "build": "ASTRO_TELEMETRY_DISABLED=1 ASTRO_LOCAL_ADAPTER=node astro build",
    "build:cloudflare": "ASTRO_TELEMETRY_DISABLED=1 ASTRO_LOCAL_ADAPTER=cloudflare astro build",
    "deploy:cloudflare": "ASTRO_TELEMETRY_DISABLED=1 ASTRO_LOCAL_ADAPTER=cloudflare astro build && wrangler deploy",
    "preview": "ASTRO_TELEMETRY_DISABLED=1 astro preview",
    "lint": "eslint .",
    "format": "prettier --write .",
    "test": "pnpm test:unit",
    "test:unit": "vitest run",
    "test:e2e": "playwright test",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:studio": "drizzle-kit studio",
    "typecheck": "ASTRO_TELEMETRY_DISABLED=1 astro check"
  },
  "dependencies": {
    "@astrojs/cloudflare": "^13.1.9",
    "@astrojs/mdx": "^5.0.4",
    "@astrojs/sitemap": "^3.6.0",
    "@neondatabase/serverless": "^1.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "astro": "^6.0.0",
    "drizzle-orm": "^0.44.6",
    "resend": "^6.1.0",
    "tailwindcss": "^4.2.4",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "@astrojs/check": "^0.9.4",
    "@astrojs/node": "^10.0.6",
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.6.0",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^8.57.1",
    "eslint-plugin-astro": "^0.34.0",
    "prettier": "^3.6.2",
    "prettier-plugin-astro": "^0.14.1",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
